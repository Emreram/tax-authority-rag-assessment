{
  "_spec": {
    "description": "Golden test set for the Dutch Tax Authority RAG system. Used in CI/CD evaluation gates (Stage 1: retrieval, Stage 2: generation). Demo set: 25 representative entries spanning the 4 archetypes plus adversarial. Production target: 200+.",
    "full_set_target": 200,
    "distribution": {
      "simple_factual_dutch": "32%",
      "complex_multi_part": "24%",
      "reference_ecli_article": "20%",
      "adversarial": "12%",
      "cross_tier_permutations": "12%"
    },
    "entry_schema": {
      "id": "unique string identifier",
      "query": "the user query text",
      "query_type": "SIMPLE | COMPLEX | REFERENCE",
      "language": "nl | en | mixed",
      "security_tier": "PUBLIC | INTERNAL | RESTRICTED | CLASSIFIED_FIOD",
      "expected_chunk_ids": "list of chunk_ids that MUST appear in retrieved top-K",
      "expected_answer_contains": "list of strings that must appear in a correct answer",
      "must_refuse": "boolean — true for out-of-scope or cross-tier adversarial queries",
      "is_adversarial": "boolean",
      "adversarial_type": "out_of_scope | cross_tier_leak | temporal_trap | null",
      "notes": "human-readable annotation"
    }
  },
